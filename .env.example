# Copy to .env. All settings are prefixed ADP_ (see adp.core.config.Settings).

ADP_PG_HOST=localhost
ADP_PG_PORT=5432
ADP_PG_DB=adp
ADP_PG_USER=adp
ADP_PG_PASSWORD=adp

ADP_S3_ENDPOINT_URL=http://localhost:9000
ADP_S3_ACCESS_KEY=minioadmin
ADP_S3_SECRET_KEY=minioadmin
ADP_BRONZE_BUCKET=bronze

ADP_MARKET_DATA_PROVIDER=yfinance

# POSOCO/Grid-India discovery. Placeholders: {yyyy} {mm} {dd} {ddmmyyyy} {ddmmyy}
# NOTE: verify the live URL/layout at implementation time; this is configurable
# precisely so a site change is an env edit, not a code change.
ADP_POSOCO_REPORT_URL_TEMPLATE=https://report.grid-india.in/ReportDownload.aspx?dt={ddmmyyyy}&type=psp

# GST e-way bill (monthly). Placeholders: {yyyy} {mm}. Verify the live URL at
# implementation time — GSTN portals move; this is config so it's an env edit.
ADP_GST_REPORT_URL_TEMPLATE=https://ewaybillgst.gov.in/Others/Statistics/EWB_{yyyy}{mm}.xlsx
# ADP_GST_LOCAL_DIR=data/gst_archive          # real archived files for backfill/CI
ADP_GST_PUBLICATION_LAG_DAYS=12

# Indian Railways freight (monthly). Placeholders: {yyyy} {mm}.
ADP_RAILWAY_REPORT_URL_TEMPLATE=https://www.indianrailways.gov.in/railwayboard/uploads/directorate/stat_econ/Freight_{yyyy}{mm}.pdf
# ADP_RAILWAY_LOCAL_DIR=data/railway_archive
ADP_RAILWAY_PUBLICATION_LAG_DAYS=3

PREFECT_API_URL=http://localhost:4200/api
